{
  "manifest_version": 3,
  "name": "Pick-a-Print — Save",
  "version": "0.1.0",
  "description": "Save 3D models from Printables, MakerWorld, Thangs and more to your personal library.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8001/*",
    "http://127.0.0.1:8001/*",
    "http://localhost:8002/*",
    "http://127.0.0.1:8002/*",
    "https://www.printables.com/*",
    "https://printables.com/*",
    "https://makerworld.com/*",
    "https://www.makerworld.com/*",
    "https://thangs.com/*",
    "https://www.thangs.com/*",
    "https://www.thingiverse.com/*",
    "https://thingiverse.com/*",
    "https://www.myminifactory.com/*",
    "https://myminifactory.com/*",
    "https://cults3d.com/*",
    "https://www.cults3d.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Pick-a-Print"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.printables.com/*",
        "https://printables.com/*",
        "https://makerworld.com/*",
        "https://www.makerworld.com/*",
        "https://thangs.com/*",
        "https://www.thangs.com/*",
        "https://www.thingiverse.com/*",
        "https://thingiverse.com/*",
        "https://www.myminifactory.com/*",
        "https://myminifactory.com/*",
        "https://cults3d.com/*",
        "https://www.cults3d.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
